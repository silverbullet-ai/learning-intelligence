from multiprocessing import Process
import time


def calculate():
    total = 0

    for i in range(10_000_000):
        total += i

    print(total)


start = time.time()

p1 = Process(target=calculate)
p2 = Process(target=calculate)

p1.start()
p2.start()

p1.join()
p2.join()

end = time.time()

print(
    f"Execution Time: {end-start:.2f} seconds"
)